# ── Base de datos ─────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI (modo "Transaction pooler")
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Auth JWT ──────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR_POR_CLAVE_SEGURA
ACCESS_TOKEN_EXPIRE_HOURS=8

# ── SMTP (Gmail institucional) ────────────────────────────────────────────────
# En Gmail: Cuenta → Seguridad → Verificación en dos pasos → Contraseñas de aplicación
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucuenta@udea.edu.co
SMTP_PASSWORD=CONTRASEÑA_DE_APLICACION_GMAIL
SMTP_FROM=MUA Biodiversidad <tucuenta@udea.edu.co>

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL pública de este servicio en Vercel (ajustar tras el primer deploy)
BASE_URL=https://tu-proyecto.vercel.app
# URL del frontend (app Expo/React Native) — usar la URL real si está publicada
FRONTEND_URL=https://tu-proyecto.vercel.app

# ── Modo depuración ───────────────────────────────────────────────────────────
# true  → activa /docs y /redoc (solo desarrollo)
# false → desactiva documentación pública (producción)
DEBUG=false

# ── NO configurar en producción ───────────────────────────────────────────────
# TEST_MODE=true   ← NUNCA en producción, expone tokens en la API
